   "source": [
    "from Bio import SeqIO
",
    "for record in SeqIO.parse('data/sample.fasta', 'fasta'):
",
    "    seq = record.seq
",
    "    print(f'ID: {record.id}, GC%: {(seq.count("G") + seq.count("C"))/len(seq)*100:.2f}, Reverse Complement: {seq.reverse_complement()}')"
   ]
  }
